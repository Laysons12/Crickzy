<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/card_background"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTournamentName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tournament Name"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="League"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_chip_selected"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Location & Ground -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTournamentLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Mumbai"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  •  "
                android:textColor="@color/divider" />

            <TextView
                android:id="@+id/tvTournamentGround"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏟️ Wankhede"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Info row: overs, ball type, team count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTournamentOvers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 overs"
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="@color/divider" />

            <TextView
                android:id="@+id/tvTournamentBallType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tennis"
                android:textSize="13sp"
                android:textColor="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="@color/divider" />

            <TextView
                android:id="@+id/tvTeamCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 Teams"
                android:textSize="13sp"
                android:textColor="@color/secondary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dates -->
        <TextView
            android:id="@+id/tvTournamentDates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="01/01/24 - 05/01/24"
            android:textSize="12sp"
            android:textColor="@color/text_hint" />

        <!-- Fee & Prize -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTournamentFee"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Fee: ₹1000"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTournamentPrize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prize: ₹50,000"
                android:textSize="13sp"
                android:textColor="@color/success"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- View Tournament Button -->
        <Button
            android:id="@+id/btnViewTournament"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="12dp"
            android:text="View Tournament"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp" />

        <!-- Delete Tournament Button -->
        <Button
            android:id="@+id/btnDeleteTournament"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:text="🗑️ Delete Tournament"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/error"
            android:textColor="@color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone"
            app:cornerRadius="10dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
