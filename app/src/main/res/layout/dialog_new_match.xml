<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/etDialogTeam1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Team 1 Name"
            android:inputType="text"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_input"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etDialogTeam2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Team 2 Name"
            android:inputType="text"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_input"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etDialogOvers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Number of Overs (default: 20)"
            android:inputType="number"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_input"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Team 1 Players (one per line)"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDialogTeam1Players"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Player 1&#10;Player 2&#10;Player 3&#10;..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_input"
            android:scrollbars="vertical"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Team 2 Players (one per line)"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etDialogTeam2Players"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Player 1&#10;Player 2&#10;Player 3&#10;..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:padding="12dp"
            android:background="@drawable/bg_rounded_input"
            android:scrollbars="vertical" />

    </LinearLayout>
</ScrollView>
