<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@drawable/bg_hero_gradient"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="20dp">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginBottom="8dp">

        <View
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_icon" />

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_cricket_logo" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvNavHeaderName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNavHeaderEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="user@crickzy.com"
        android:textColor="#CCCCEE"
        android:textSize="13sp" />

</LinearLayout>
